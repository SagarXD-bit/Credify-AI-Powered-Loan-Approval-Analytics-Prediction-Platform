# Credify Environment Variables
# Copy this file to .env and fill in your values

# ── FastAPI / Backend ──
PORT=8000
CREDIFY_RUNTIME_DIR=./runtime

# ── Database ──
# Local: SQLite (default, no env var needed)
# Production: PostgreSQL via Neon
DATABASE_URL=

# ── React Frontend ──
# Local dev server port
FRONTEND_PORT=19058
# Base path (default / for local, /credify/ for custom subpath)
BASE_PATH=/
VITE_API_BASE_URL=http://localhost:8000

# ── Logging ──
LOG_LEVEL=info
NODE_ENV=development
